@model BookCore.ViewModels.CatalogoIndiceViewModel

@{
    ViewData["Title"] = "Catálogo";
}

<div class="contenedor-pagina">

    <div class="mb-4">
        <h1>Catálogo de libros</h1>

        <p class="text-muted">
            Consulta los libros y su disponibilidad.
        </p>
    </div>

    <div class="tarjeta-panel mb-4">

        <form asp-action="Index"
              method="get"
              class="row g-3">

            <div class="col-md-7">
                <label asp-for="Busqueda"
                       class="form-label">
                    Buscar
                </label>

                <input asp-for="Busqueda"
                       class="form-control"
                       placeholder="Título, autor o editorial" />
            </div>

            <div class="col-md-3">
                <label asp-for="CategoriaId"
                       class="form-label">
                    Categoría
                </label>

                <select asp-for="CategoriaId"
                        asp-items="Model.Categorias"
                        class="form-select">

                    <option value="">
                        Todas las categorías
                    </option>

                </select>
            </div>

            <div class="col-md-2 d-flex align-items-end gap-2">

                <button type="submit"
                        class="btn btn-primary">
                    Buscar
                </button>

                <a asp-action="Index"
                   class="btn btn-outline-secondary">
                    Limpiar
                </a>

            </div>

        </form>

    </div>

    @if (!Model.Libros.Any())
    {
        <div class="alert alert-info">
            No se encontraron libros.
        </div>
    }
    else
    {
        <div class="row">

            @foreach (var libro in Model.Libros)
            {
                <div class="col-md-6 col-lg-4 mb-4">

                    <div class="card h-100">

                        @if (!string.IsNullOrWhiteSpace(
                            libro.ImagenUrl))
                        {
                            <img src="@libro.ImagenUrl"
                                 class="card-img-top"
                                 alt="Portada de @libro.Titulo"
                                 style="height: 300px; object-fit: contain;" />
                        }

                        <div class="card-body d-flex flex-column">

                            <h2 class="h5 card-title">
                                @libro.Titulo
                            </h2>

                            <p class="text-muted mb-2">
                                @libro.Autores
                            </p>

                            <p class="mb-2">
                                <strong>Categoría:</strong>
                                @libro.CategoriaNombre
                            </p>

                            @if (libro.Disponible)
                            {
                                <span class="badge bg-success
                                    align-self-start mb-3">
                                    @libro.EjemplaresDisponibles disponible(s)
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary
                                    align-self-start mb-3">
                                    No disponible
                                </span>
                            }

                            <a asp-action="Detalle"
                               asp-route-id="@libro.LibroId"
                               class="btn btn-outline-primary mt-auto">
                                Ver detalle
                            </a>

                        </div>

                    </div>

                </div>
            }

        </div>
    }

</div>