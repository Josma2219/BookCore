@model BookCore.ViewModels.CuentaUsuarioFormularioViewModel

@{
    ViewData["Title"] = "Configurar acceso";
}

<div class="contenedor-pagina">
    <div class="tarjeta-panel">

        <h1>Configurar acceso</h1>

        <p class="text-muted">
            Usuario de biblioteca:
            <strong>@Model.UsuarioNombreCompleto</strong>
        </p>

        @if (!Model.TieneCuenta)
        {
            <div class="alert alert-info">
                Este usuario todavía no tiene una cuenta
                para iniciar sesión.
            </div>
        }

        <form asp-action="Configurar"
              method="post">

            <input asp-for="CuentaUsuarioId"
                   type="hidden" />

            <input asp-for="UsuarioBibliotecaId"
                   type="hidden" />

            <input asp-for="TieneCuenta"
                   type="hidden" />

            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3">
            </div>

            <div class="row">

                <div class="col-md-6 mb-3">

                    <label asp-for="NombreUsuario"
                           class="form-label">
                    </label>

                    <input asp-for="NombreUsuario"
                           class="form-control"
                           autocomplete="username" />

                    <span asp-validation-for="NombreUsuario"
                          class="text-danger">
                    </span>

                </div>

                <div class="col-md-6 mb-3">

                    <label asp-for="Correo"
                           class="form-label">
                    </label>

                    <input asp-for="Correo"
                           class="form-control"
                           type="email" />

                    <span asp-validation-for="Correo"
                          class="text-danger">
                    </span>

                </div>

            </div>

            <div class="row">

                <div class="col-md-6 mb-3">

                    <label asp-for="ContrasenaNueva"
                           class="form-label">
                    </label>

                    <input asp-for="ContrasenaNueva"
                           class="form-control"
                           autocomplete="new-password" />

                    <span asp-validation-for="ContrasenaNueva"
                          class="text-danger">
                    </span>

                </div>

                <div class="col-md-6 mb-3">

                    <label asp-for="ConfirmarContrasena"
                           class="form-label">
                    </label>

                    <input asp-for="ConfirmarContrasena"
                           class="form-control"
                           autocomplete="new-password" />

                    <span asp-validation-for="ConfirmarContrasena"
                          class="text-danger">
                    </span>

                </div>

            </div>

            @if (Model.TieneCuenta)
            {
                <div class="form-text mb-3">
                    Deja las contraseñas vacías para conservar
                    la contraseña actual.
                </div>
            }

            <div class="form-check mb-4">

                <input asp-for="Activo"
                       class="form-check-input" />

                <label asp-for="Activo"
                       class="form-check-label">
                </label>

            </div>

            <div class="d-flex gap-2">

                <button type="submit"
                        class="btn btn-primary">
                    Guardar acceso
                </button>

                <a asp-controller="UsuariosBiblioteca"
                   asp-action="Detalle"
                   asp-route-id="@Model.UsuarioBibliotecaId"
                   class="btn btn-outline-secondary">
                    Cancelar
                </a>

            </div>

        </form>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}