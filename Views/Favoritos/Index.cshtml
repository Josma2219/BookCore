@model IEnumerable<BookCore.ViewModels.FavoritoLibroViewModel>

@{
    ViewData["Title"] = "Mis favoritos";
}

<div class="contenedor-pagina">

    <div class="tarjeta-panel mb-4">

        <div class="d-flex justify-content-between
            align-items-center">

            <div>
                <h1>Mis favoritos</h1>

                <p class="text-muted mb-0">
                    Libros que guardaste para consultar después.
                </p>
            </div>

            <a asp-controller="Catalogo"
               asp-action="Index"
               class="btn btn-primary">
                Explorar catálogo
            </a>

        </div>

    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Todavía no has agregado libros a favoritos.
        </div>
    }
    else
    {
        <div class="row">

            @foreach (var libro in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">

                    <div class="card h-100">

                        @if (!string.IsNullOrWhiteSpace(
                            libro.ImagenUrl))
                        {
                            <img src="@libro.ImagenUrl"
                                 class="card-img-top"
                                 alt="Portada de @libro.Titulo"
                                 style="height: 260px;
                            object-fit: contain;" />
                        }

                        <div class="card-body d-flex flex-column">

                            <h2 class="h5">
                                @libro.Titulo
                            </h2>

                            <p class="text-muted">
                                @libro.Autores
                            </p>

                            <p>
                                <strong>Categoría:</strong>
                                @libro.Categoria
                            </p>

                            @if (libro.EjemplaresDisponibles > 0)
                            {
                                <span class="badge bg-success
                                    align-self-start mb-3">
                                    @libro.EjemplaresDisponibles
                                    disponible(s)
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary
                                    align-self-start mb-3">
                                    No disponible
                                </span>
                            }

                            <div class="d-flex gap-2 mt-auto">

                                <a asp-controller="Catalogo"
                                   asp-action="Detalle"
                                   asp-route-id="@libro.LibroId"
                                   class="btn btn-outline-primary">
                                    Ver detalle
                                </a>

                                <form asp-action="Eliminar"
                                      method="post">

                                    <input type="hidden"
                                           name="libroId"
                                           value="@libro.LibroId" />

                                    <button type="submit"
                                            class="btn btn-outline-danger">
                                        Quitar
                                    </button>

                                </form>

                            </div>

                        </div>

                    </div>

                </div>
            }

        </div>
    }

</div>