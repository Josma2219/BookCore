<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - BookCore</title>

    <script type="importmap"></script>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/BookCore.styles.css"
          asp-append-version="true" />
</head>

<body>
    <header>

        <nav class="navbar navbar-expand-lg
            navbar-light bg-white
            border-bottom box-shadow mb-3">

            <div class="container-fluid">

                <a class="navbar-brand fw-bold"
                   asp-controller="Home"
                   asp-action="Index">
                    BookCore
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#menuPrincipal"
                        aria-controls="menuPrincipal"
                        aria-expanded="false"
                        aria-label="Mostrar navegación">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div id="menuPrincipal"
                     class="collapse navbar-collapse">

                    <ul class="navbar-nav me-auto">

                        <!-- Estos enlaces siempre son públicos -->

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Home"
                               asp-action="Index">
                                Inicio
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Catalogo"
                               asp-action="Index">
                                Catálogo
                            </a>
                        </li>

                        @if (User.IsInRole("Administrador"))
                        {
                            <li class="nav-item dropdown">

                                <a class="nav-link dropdown-toggle"
                                   href="#"
                                   role="button"
                                   data-bs-toggle="dropdown"
                                   aria-expanded="false">
                                    Administración
                                </a>

                                <ul class="dropdown-menu">

                                    <li>
                                        <a class="dropdown-item"
                                           asp-controller="Libros"
                                           asp-action="Index">
                                            Libros
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item"
                                           asp-controller="Ejemplares"
                                           asp-action="Index">
                                            Ejemplares
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item"
                                           asp-controller="Autores"
                                           asp-action="Index">
                                            Autores
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item"
                                           asp-controller="Categorias"
                                           asp-action="Index">
                                            Categorías
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item"
                                           asp-controller="UsuariosBiblioteca"
                                           asp-action="Index">
                                            Usuarios
                                        </a>
                                    </li>

                                    <li>
                                        <hr class="dropdown-divider" />
                                    </li>

                                    <li>
                                        <a class="dropdown-item"
                                           asp-controller="Prestamos"
                                           asp-action="Index">
                                            Préstamos y devoluciones
                                        </a>
                                    </li>

                                </ul>

                            </li>
                        }

                    </ul>

                    <ul class="navbar-nav">

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item d-flex
                                align-items-center me-3">

                                <span class="navbar-text">
                                    Usuario:
                                    <strong>
                                        @User.Identity.Name
                                    </strong>
                                </span>

                            </li>

                            <li class="nav-item">

                                <form asp-controller="Cuenta"
                                      asp-action="CerrarSesion"
                                      method="post">

                                    <button type="submit"
                                            class="btn btn-outline-danger">
                                        Cerrar sesión
                                    </button>

                                </form>

                            </li>
                        }
                        else
                        {
                            <li class="nav-item">

                                <a class="btn btn-outline-primary"
                                   asp-controller="Cuenta"
                                   asp-action="IniciarSesion">
                                    Iniciar sesión
                                </a>

                            </li>
                        }

                    </ul>

                </div>

            </div>

        </nav>

    </header>

    <div class="container">

        <main role="main" class="pb-3">

            <partial name="_Mensajes" />

            @RenderBody()

        </main>

    </div>

    <footer class="border-top footer text-muted">

        <div class="container">
            &copy; @DateTime.Now.Year - BookCore
        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js"
            asp-append-version="true">
    </script>

    @await RenderSectionAsync(
        "Scripts",
        required: false)
</body>
</html>