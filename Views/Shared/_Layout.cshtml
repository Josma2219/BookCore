<!DOCTYPE html>
<html lang="es">

@{
    // Controladores que forman parte de la zona de administración.
    // Ahí se aplica la tipografía "seria" (ver .zona-admin en site.css).
    var controladoresAdmin = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
    {
        "Panel", "Libros", "Autores", "Categorias",
        "Ejemplares", "UsuariosBiblioteca", "Prestamos"
    };

    var controladorActual =
        ViewContext.RouteData.Values["controller"]?.ToString() ?? "";

    var esZonaAdmin = controladoresAdmin.Contains(controladorActual);
}

<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width,
    initial-scale=1.0" />

    <title>@ViewData["Title"] - BookCore</title>

    <script type="importmap"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link rel="stylesheet"
          href="~/BookCore.styles.css"
          asp-append-version="true" />
          
          <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    
</head>

<body class="@(esZonaAdmin ? "zona-admin" : "")">

    <header>

        <nav class="navbar
            navbar-expand-lg
            navbar-dark
            mb-3">

            <div class="container-fluid">

                <a class="navbar-brand fw-bold d-flex align-items-center gap-2"
                   asp-controller="Home"
                   asp-action="Index">

                    <span class="navbar-logo-chip">
                        <img src="~/images/logo-bookcore-compacto.png"
                             alt="BookCore"
                             class="navbar-logo" />
                    </span>

                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#menuPrincipal"
                        aria-controls="menuPrincipal"
                        aria-expanded="false"
                        aria-label="Mostrar navegación">

                    <span class="navbar-toggler-icon">
                    </span>

                </button>

                <div id="menuPrincipal"
                     class="collapse navbar-collapse">

                    <ul class="navbar-nav me-auto">

                        <!-- Opciones públicas para todos -->

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="Home"
                               asp-action="Index">

                                Inicio

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="Catalogo"
                               asp-action="Index">

                                Catálogo

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="Home"
                               asp-action="SobreNosotros">

                                Sobre Nosotros

                            </a>

                        </li>

                        <!-- Menú administrativo -->
                        @if (User.IsInRole("Administrador"))
                        {
                            <li class="nav-item dropdown">

                                <a class="nav-link dropdown-toggle"
                                   href="#"
                                   role="button"
                                   data-bs-toggle="dropdown"
                                   aria-expanded="false">

                                    Administración

                                </a>

                                <ul class="dropdown-menu">

                                    <li>

                                        <a class="dropdown-item"
                                           asp-controller="Panel"
                                           asp-action="Index">

                                            Panel administrativo

                                        </a>

                                    </li>

                                    <li>
                                        <hr class="dropdown-divider" />
                                    </li>

                                    <li>

                                        <a class="dropdown-item"
                                           asp-controller="Libros"
                                           asp-action="Index">

                                            Libros

                                        </a>

                                    </li>

                                    <li>

                                        <a class="dropdown-item"
                                           asp-controller="Ejemplares"
                                           asp-action="Index">

                                            Ejemplares

                                        </a>

                                    </li>

                                    <li>

                                        <a class="dropdown-item"
                                           asp-controller="Autores"
                                           asp-action="Index">

                                            Autores

                                        </a>

                                    </li>

                                    <li>

                                        <a class="dropdown-item"
                                           asp-controller="Categorias"
                                           asp-action="Index">

                                            Categorías

                                        </a>

                                    </li>

                                    <li>

                                        <a class="dropdown-item"
                                           asp-controller="UsuariosBiblioteca"
                                           asp-action="Index">

                                            Usuarios de biblioteca

                                        </a>

                                    </li>

                                    <li>
                                        <hr class="dropdown-divider" />
                                    </li>

                                    <li>

                                        <a class="dropdown-item"
                                           asp-controller="Prestamos"
                                           asp-action="Index">

                                            Préstamos y devoluciones

                                        </a>

                                    </li>

                                </ul>

                            </li>
                        }

                        <!-- Menú para usuarios generales -->
                        @if (User.IsInRole("Usuario"))
                        {
                            <li class="nav-item dropdown">

                                <a class="nav-link dropdown-toggle"
                                   href="#"
                                   role="button"
                                   data-bs-toggle="dropdown"
                                   aria-expanded="false">

                                    Mi biblioteca

                                </a>

                                <ul class="dropdown-menu">

                                    <li>

                                        <a class="dropdown-item"
                                           asp-controller="MiCuenta"
                                           asp-action="Index">

                                            Mi cuenta

                                        </a>

                                    </li>

                                    <li>

                                        <a class="dropdown-item"
                                           asp-controller="MiCuenta"
                                           asp-action="Historial">

                                            Mi historial

                                        </a>

                                    </li>

                                    <li>

                                        <a class="dropdown-item"
                                           asp-controller="Favoritos"
                                           asp-action="Index">

                                            Mis favoritos

                                        </a>

                                    </li>

                                </ul>

                            </li>
                        }

                    </ul>

                    <ul class="navbar-nav">

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item
                                d-flex
                                align-items-center
                                me-3">

                                <span class="navbar-text">

                                    Usuario:

                                    <strong>
                                        @User.Identity.Name
                                    </strong>

                                </span>

                            </li>

                            <li class="nav-item">

                                <form asp-controller="Cuenta"
                                      asp-action="CerrarSesion"
                                      method="post">

                                    <button type="submit"
                                            class="btn
                                        btn-danger">

                                        Cerrar sesión

                                    </button>

                                </form>

                            </li>
                        }
                        else
                        {
                            <li class="nav-item">

                                <a class="btn
                                    btn-success"
                                   asp-controller="Cuenta"
                                   asp-action="IniciarSesion">

                                    Iniciar sesión

                                </a>

                            </li>
                        }

                    </ul>

                </div>

            </div>

        </nav>

    </header>

    <div class="container contenido-principal">

        <main role="main"
              class="pb-3">

            <partial name="_Mensajes" />

            @RenderBody()

        </main>

    </div>

    <footer class="footer">

        <div class="container-fluid footer-container">

            <div class="footer-columnas">

                <div class="footer-columna footer-columna-marca">

                    <span class="navbar-logo-chip mb-3 d-inline-flex">
                        <img src="~/images/logo-bookcore-compacto.png"
                             alt="BookCore"
                             class="footer-logo" />
                    </span>

                    <p>
                        Una biblioteca moderna para encontrar, consultar
                        y solicitar en préstamo miles de libros de forma
                        simple y organizada.
                    </p>

                    <div class="footer-redes">

                        <a href="#" class="footer-red-icono" title="Facebook">
                            <i class="bi bi-facebook"></i>
                        </a>

                        <a href="#" class="footer-red-icono" title="Instagram">
                            <i class="bi bi-instagram"></i>
                        </a>

                        <a href="#" class="footer-red-icono" title="X (Twitter)">
                            <i class="bi bi-twitter-x"></i>
                        </a>

                        <a href="#" class="footer-red-icono" title="TikTok">
                            <i class="bi bi-tiktok"></i>
                        </a>

                        <a href="#" class="footer-red-icono" title="YouTube">
                            <i class="bi bi-youtube"></i>
                        </a>

                    </div>

                </div>

                <div class="footer-columna">
                    <h3>Explorar</h3>
                    <ul>
                        <li>
                            <a asp-controller="Home" asp-action="Index">
                                Inicio
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Catalogo" asp-action="Index">
                                Catálogo
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Home" asp-action="SobreNosotros">
                                Sobre Nosotros
                            </a>
                        </li>
                    </ul>
                </div>

                <div class="footer-columna">
                    <h3>Mi cuenta</h3>
                    <ul>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("Usuario"))
                            {
                                <li>
                                    <a asp-controller="MiCuenta" asp-action="Index">
                                        Mi cuenta
                                    </a>
                                </li>
                                <li>
                                    <a asp-controller="Favoritos" asp-action="Index">
                                        Mis favoritos
                                    </a>
                                </li>
                                <li>
                                    <a asp-controller="MiCuenta" asp-action="Historial">
                                        Mi historial
                                    </a>
                                </li>
                            }

                            @if (User.IsInRole("Administrador"))
                            {
                                <li>
                                    <a asp-controller="Panel" asp-action="Index">
                                        Panel administrativo
                                    </a>
                                </li>
                            }
                        }
                        else
                        {
                            <li>
                                <a asp-controller="Cuenta" asp-action="IniciarSesion">
                                    Iniciar sesión
                                </a>
                            </li>
                        }
                    </ul>
                </div>

                <div class="footer-columna">
                    <h3>Tecnología</h3>
                    <ul>
                        <li>
                            <a asp-controller="Home" asp-action="MoonByte">
                                MoonByte
                            </a>
                        </li>
                    </ul>
                </div>

            </div>

            <div class="footer-inferior">

                <span>
                    &copy; @DateTime.Now.Year - Biblioteca Inteligente
                </span>

                <span class="d-flex align-items-center gap-2">
                    Hecho por
                    <img src="~/images/logo-moonbyte.png"
                         alt="MoonByte"
                         class="footer-logo" />
                    MoonByte
                </span>

            </div>

        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js">
    </script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js">
    </script>

    <script src="~/js/site.js"
            asp-append-version="true">
    </script>

    @await RenderSectionAsync(
        "Scripts",
        required: false)

</body>

</html>