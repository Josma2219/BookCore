@model BookCore.ViewModels.InicioSesionViewModel

@{
    ViewData["Title"] = "Iniciar sesión";
}

<div class="contenedor-pagina">
    <div class="row justify-content-center">

        <div class="col-md-6 col-lg-5">

            <div class="tarjeta-panel">

                <div class="text-center mb-4">
                    <h1 class="h2">
                        Iniciar sesión
                    </h1>

                    <p class="text-muted">
                        Acceso administrativo de BookCore
                    </p>
                </div>

                <form asp-action="IniciarSesion"
                      method="post">

                    <input asp-for="ReturnUrl"
                           type="hidden" />

                    <div asp-validation-summary="ModelOnly"
                         class="alert alert-danger">
                    </div>

                    <div class="mb-3">
                        <label asp-for="Identificador"
                               class="form-label">
                        </label>

                        <input asp-for="Identificador"
                               class="form-control"
                               autocomplete="username"
                               placeholder="Usuario o correo" />

                        <span asp-validation-for="Identificador"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Contrasena"
                               class="form-label">
                        </label>

                        <input asp-for="Contrasena"
                               class="form-control"
                               autocomplete="current-password"
                               placeholder="Contraseña" />

                        <span asp-validation-for="Contrasena"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="Recordarme"
                               class="form-check-input" />

                        <label asp-for="Recordarme"
                               class="form-check-label">
                        </label>
                    </div>

                    <button type="submit"
                            class="btn btn-primary w-100">
                        Entrar
                    </button>

                </form>

            </div>

        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}