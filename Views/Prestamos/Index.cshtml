@model BookCore.ViewModels.PrestamoIndiceViewModel

@{
    ViewData["Title"] = "Préstamos";
}

@functions {
    string ObtenerIniciales(string nombreCompleto)
    {
        var partes = (nombreCompleto ?? "")
            .Split(' ', StringSplitOptions.RemoveEmptyEntries);

        if (partes.Length == 0)
        {
            return "?";
        }

        if (partes.Length == 1)
        {
            return partes[0].Substring(0, 1).ToUpper();
        }

        return (partes[0].Substring(0, 1) + partes[1].Substring(0, 1)).ToUpper();
    }

    string ObtenerClaseColor(int indice)
    {
        string[] clases = { "c1", "c2", "c3", "c4", "c5" };
        return clases[indice % clases.Length];
    }
}

<div class="contenedor-pagina">
    <div class="tarjeta-panel">

        <div class="d-flex justify-content-between
            align-items-center mb-4">

            <div>
                <h1 class="mb-1">
                    Préstamos
                </h1>

                <p class="text-muted mb-0">
                    Registra préstamos, devoluciones y consulta el historial.
                </p>
            </div>

            <a asp-action="Crear"
               class="btn btn-primary">
                Nuevo préstamo
            </a>
        </div>

        <form asp-action="Index"
              method="get"
              class="row g-3 mb-4">

            <div class="col-md-4">
                <label asp-for="Busqueda"
                       class="form-label">
                    Búsqueda
                </label>

                <input asp-for="Busqueda"
                       class="form-control"
                       placeholder="Usuario, cédula, libro o ejemplar" />
            </div>

            <div class="col-md-2">
                <label asp-for="Estado"
                       class="form-label">
                    Estado
                </label>

                <select asp-for="Estado"
                        asp-items="Model.Estados"
                        class="form-select">

                    <option value="">
                        Todos
                    </option>

                </select>
            </div>

            <div class="col-md-2">
                <label asp-for="FechaDesde"
                       class="form-label">
                    Desde
                </label>

                <input asp-for="FechaDesde"
                       type="date"
                       class="form-control" />
            </div>

            <div class="col-md-2">
                <label asp-for="FechaHasta"
                       class="form-label">
                    Hasta
                </label>

                <input asp-for="FechaHasta"
                       type="date"
                       class="form-control" />
            </div>

            <div class="col-md-2 d-flex
                align-items-end gap-2">

                <button type="submit"
                        class="btn btn-outline-primary">
                    Buscar
                </button>

                <a asp-action="Index"
                   class="btn btn-outline-secondary">
                    Limpiar
                </a>
            </div>

        </form>

        @if (!Model.Prestamos.Any())
        {
            <div class="alert alert-info mb-0">
                No se encontraron préstamos.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">

                    <thead>
                        <tr>
                            <th>Usuario <i class="bi bi-arrow-down-up orden-columna"></i></th>
                            <th>Libro <i class="bi bi-arrow-down-up orden-columna"></i></th>
                            <th class="col-oculta-angosta">Ejemplar <i class="bi bi-arrow-down-up orden-columna"></i></th>
                            <th>Préstamo <i class="bi bi-arrow-down-up orden-columna"></i></th>
                            <th>Vencimiento <i class="bi bi-arrow-down-up orden-columna"></i></th>
                            <th>Estado <i class="bi bi-arrow-down-up orden-columna"></i></th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @{
                            int filaIndice = 0;
                        }

                        @foreach (var prestamo in Model.Prestamos)
                        {
                            var claseColor = ObtenerClaseColor(filaIndice);

                            <tr>
                                <td>
                                    <div class="usuario-celda">
                                        <span class="avatar-iniciales @claseColor">
                                            @ObtenerIniciales(prestamo.UsuarioNombreCompleto)
                                        </span>
                                        <div>
                                            <div>@prestamo.UsuarioNombreCompleto</div>
                                            <div class="texto-secundario">
                                                <i class="bi bi-person-vcard"></i>
                                                @prestamo.UsuarioCedula
                                            </div>
                                        </div>
                                    </div>
                                </td>

                                <td>
                                    <div class="libro-celda">
                                        <span class="icono-libro-mini @claseColor">
                                            <i class="bi bi-book"></i>
                                        </span>
                                        @prestamo.LibroTitulo
                                    </div>
                                </td>

                                <td class="col-oculta-angosta">
                                    <span class="pastilla-codigo">
                                        @prestamo.EjemplarCodigo
                                    </span>
                                </td>

                                <td>
                                    <span class="fecha-con-icono">
                                        <i class="bi bi-calendar3"></i>
                                        @(prestamo.FechaPrestamo.ToString(
                                            "dd/MM/yyyy HH:mm"))
                                    </span>
                                </td>

                                <td>
                                    <span class="fecha-con-icono">
                                        <i class="bi bi-calendar-event"></i>
                                        @(prestamo.FechaVencimiento.ToString(
                                            "dd/MM/yyyy"))
                                    </span>

                                    @if (prestamo.DiasAtraso > 0)
                                    {
                                        <div class="text-danger small">
                                            @prestamo.DiasAtraso día(s) de atraso
                                        </div>
                                    }
                                </td>

                                <td>
                                    @switch (prestamo.Estado)
                                    {
                                        case "Activo":
                                            <span class="estado-punto activo">
                                                Activo
                                            </span>
                                            break;

                                        case "Vencido":
                                            <span class="estado-punto vencido">
                                                Vencido
                                            </span>
                                            break;

                                        default:
                                            <span class="estado-punto devuelto">
                                                Devuelto
                                            </span>
                                            break;
                                    }
                                </td>

                                <td>
                                    <div class="acciones-tabla">

                                        <a asp-action="Detalle"
                                           asp-route-id="@prestamo.PrestamoId"
                                           class="accion-icono ver"
                                           title="Ver detalle">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        @if (prestamo.PuedeDevolverse)
                                        {
                                            <a asp-action="Devolver"
                                               asp-route-id="@prestamo.PrestamoId"
                                               class="accion-icono exito"
                                               title="Registrar devolución">
                                                <i class="bi bi-arrow-return-left"></i>
                                            </a>
                                        }

                                    </div>
                                </td>
                            </tr>

                            filaIndice++;
                        }
                    </tbody>

                </table>
            </div>
        }

    </div>
</div>