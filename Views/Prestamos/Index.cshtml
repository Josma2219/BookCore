@model BookCore.ViewModels.PrestamoIndiceViewModel

@{
    ViewData["Title"] = "Préstamos";
}

<div class="contenedor-pagina">
    <div class="tarjeta-panel">

        <div class="d-flex justify-content-between
            align-items-center mb-4">

            <div>
                <h1 class="mb-1">
                    Préstamos
                </h1>

                <p class="text-muted mb-0">
                    Registra préstamos, devoluciones y consulta el historial.
                </p>
            </div>

            <a asp-action="Crear"
               class="btn btn-primary">
                Nuevo préstamo
            </a>
        </div>

        <form asp-action="Index"
              method="get"
              class="row g-3 mb-4">

            <div class="col-md-4">
                <label asp-for="Busqueda"
                       class="form-label">
                    Búsqueda
                </label>

                <input asp-for="Busqueda"
                       class="form-control"
                       placeholder="Usuario, cédula, libro o ejemplar" />
            </div>

            <div class="col-md-2">
                <label asp-for="Estado"
                       class="form-label">
                    Estado
                </label>

                <select asp-for="Estado"
                        asp-items="Model.Estados"
                        class="form-select">

                    <option value="">
                        Todos
                    </option>

                </select>
            </div>

            <div class="col-md-2">
                <label asp-for="FechaDesde"
                       class="form-label">
                    Desde
                </label>

                <input asp-for="FechaDesde"
                       type="date"
                       class="form-control" />
            </div>

            <div class="col-md-2">
                <label asp-for="FechaHasta"
                       class="form-label">
                    Hasta
                </label>

                <input asp-for="FechaHasta"
                       type="date"
                       class="form-control" />
            </div>

            <div class="col-md-2 d-flex
                align-items-end gap-2">

                <button type="submit"
                        class="btn btn-outline-primary">
                    Buscar
                </button>

                <a asp-action="Index"
                   class="btn btn-outline-secondary">
                    Limpiar
                </a>
            </div>

        </form>

        @if (!Model.Prestamos.Any())
        {
            <div class="alert alert-info mb-0">
                No se encontraron préstamos.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">

                    <thead>
                        <tr>
                            <th>Usuario</th>
                            <th>Libro</th>
                            <th>Ejemplar</th>
                            <th>Préstamo</th>
                            <th>Vencimiento</th>
                            <th>Estado</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var prestamo in Model.Prestamos)
                        {
                            <tr>
                                <td>
                                    <strong>
                                        @prestamo.UsuarioNombreCompleto
                                    </strong>

                                    <div class="text-muted small">
                                        @prestamo.UsuarioCedula
                                    </div>
                                </td>

                                <td>
                                    @prestamo.LibroTitulo
                                </td>

                                <td>
                                    @prestamo.EjemplarCodigo
                                </td>

                                <td>
                                    @(prestamo.FechaPrestamo.ToString(
                                        "dd/MM/yyyy HH:mm"))
                                </td>

                                <td>
                                    @(prestamo.FechaVencimiento.ToString(
                                        "dd/MM/yyyy"))

                                    @if (prestamo.DiasAtraso > 0)
                                    {
                                        <div class="text-danger small">
                                            @prestamo.DiasAtraso día(s) de atraso
                                        </div>
                                    }
                                </td>

                                <td>
                                    @switch (prestamo.Estado)
                                    {
                                        case "Activo":
                                            <span class="badge bg-primary">
                                                Activo
                                            </span>
                                            break;

                                        case "Vencido":
                                            <span class="badge bg-danger">
                                                Vencido
                                            </span>
                                            break;

                                        default:
                                            <span class="badge bg-success">
                                                Devuelto
                                            </span>
                                            break;
                                    }
                                </td>

                                <td>
                                    <div class="d-flex justify-content-end gap-2">

                                        <a asp-action="Detalle"
                                           asp-route-id="@prestamo.PrestamoId"
                                           class="btn btn-sm btn-outline-info">
                                            Detalle
                                        </a>

                                        @if (prestamo.PuedeDevolverse)
                                        {
                                            <a asp-action="Devolver"
                                               asp-route-id="@prestamo.PrestamoId"
                                               class="btn btn-sm btn-outline-success">
                                                Devolver
                                            </a>
                                        }

                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>
        }

    </div>
</div>