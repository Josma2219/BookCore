@{
    ViewData["Title"] = "Inicio";
}

<div class="contenedor-pagina">

    <div class="tarjeta-panel text-center py-5">

        <h1 class="display-4 fw-bold">
            BookCore
        </h1>

        <p class="lead text-muted mt-3">
            Consulta libros, autores, categorías
            y disponibilidad de ejemplares.
        </p>

        <div class="d-flex justify-content-center
            flex-wrap gap-2 mt-4">

            <a asp-controller="Catalogo"
               asp-action="Index"
               class="btn btn-primary btn-lg">
                Explorar catálogo
            </a>

            @if (User.IsInRole("Administrador"))
            {
                <a asp-controller="Panel"
                   asp-action="Index"
                   class="btn btn-outline-primary btn-lg">
                    Abrir panel administrativo
                </a>
            }
            else
            {
                <a asp-controller="Cuenta"
                   asp-action="IniciarSesion"
                   class="btn btn-outline-secondary btn-lg">
                    Acceso administrativo
                </a>
            }

        </div>

    </div>

    <div class="row mt-4">

        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body">

                    <h2 class="h4">
                        Buscar libros
                    </h2>

                    <p class="text-muted mb-0">
                        Localiza libros por título, autor
                        o categoría.
                    </p>

                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body">

                    <h2 class="h4">
                        Consultar disponibilidad
                    </h2>

                    <p class="text-muted mb-0">
                        Revisa cuántos ejemplares están
                        disponibles actualmente.
                    </p>

                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body">

                    <h2 class="h4">
                        Información detallada
                    </h2>

                    <p class="text-muted mb-0">
                        Consulta autores, editorial,
                        publicación y descripción.
                    </p>

                </div>
            </div>
        </div>

    </div>

</div>