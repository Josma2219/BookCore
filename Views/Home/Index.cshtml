@{
    ViewData["Title"] = "Inicio";
}

<div class="hero-bookcore">

    <div class="hero-overlay"></div>

    <div class="container">

        <div class="row align-items-center min-vh-75">

            <div class="col-lg-7">

                <span class="badge bg-success px-4 py-2 mb-4 rounded-pill shadow">
                    Biblioteca Inteligente
                </span>

                <h1 class="display-2 fw-bold text-white">

                    Descubre un nuevo
                    <span class="text-success">
                        mundo de libros
                    </span>

                </h1>

                <p class="lead text-light mt-4 mb-5">

                    Explora miles de libros, encuentra autores,
                    consulta disponibilidad en tiempo real y administra
                    tu biblioteca desde una plataforma moderna.

                </p>

                <div class="d-flex flex-wrap gap-3">

                    <a asp-controller="Catalogo"
                       asp-action="Index"
                       class="btn btn-success btn-lg px-5 py-3 shadow">

                        📚 Explorar Catálogo

                    </a>

                    @if (User.IsInRole("Administrador"))
                    {
                        <a asp-controller="Panel"
                           asp-action="Index"
                           class="btn btn-light btn-lg px-5 py-3">

                            ⚙ Panel Administrativo

                        </a>
                    }
                    else
                    {
                        <a asp-controller="Cuenta"
                           asp-action="IniciarSesion"
                           class="btn btn-outline-light btn-lg px-5 py-3">

                            Iniciar Sesión

                        </a>
                    }

                </div>

            </div>

            <div class="col-lg-5 text-center mt-5 mt-lg-0">

                <div class="glass-card">

                    <div class="display-1 mb-3">

                        📚

                    </div>

                    <h3 class="fw-bold">

                        BookCORE

                    </h3>

                    <p class="mb-4">

                        Gestiona préstamos, autores,
                        categorías y disponibilidad
                        desde un solo lugar.

                    </p>

                    <div class="row">

                        <div class="col-4">

                            <h2 class="fw-bold text-success">

                                24/7

                            </h2>

                            <small>

                                Disponible

                            </small>

                        </div>

                        <div class="col-4">

                            <h2 class="fw-bold text-success">

                                100%

                            </h2>

                            <small>

                                Seguro

                            </small>

                        </div>

                        <div class="col-4">

                            <h2 class="fw-bold text-success">

                                ∞

                            </h2>

                            <small>

                                Libros

                            </small>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

<div class="container mt-5">

    <div class="row g-4">

        <div class="col-lg-4">

            <div class="feature-card">

                <div class="feature-icon">

                    🔍

                </div>

                <h3>

                    Búsqueda Inteligente

                </h3>

                <p>

                    Encuentra cualquier libro por título,
                    autor, categoría o editorial
                    en cuestión de segundos.

                </p>

            </div>

        </div>

        <div class="col-lg-4">

            <div class="feature-card">

                <div class="feature-icon">

                    📖

                </div>

                <h3>

                    Catálogo Completo

                </h3>

                <p>

                    Consulta la información completa
                    de cada libro y su disponibilidad.

                </p>

            </div>

        </div>

        <div class="col-lg-4">

            <div class="feature-card">

                <div class="feature-icon">

                    🚀

                </div>

                <h3>

                    Gestión Moderna

                </h3>

                <p>

                    Administra préstamos,
                    devoluciones y usuarios
                    desde una interfaz moderna.

                </p>

            </div>

        </div>

    </div>

</div>