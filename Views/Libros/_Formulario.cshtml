@model BookCore.ViewModels.LibroFormularioViewModel

<input asp-for="LibroId"
       type="hidden" />

<div asp-validation-summary="ModelOnly"
     class="text-danger mb-3">
</div>

<div class="row">
    <div class="col-md-8 mb-3">
        <label asp-for="Titulo"
               class="form-label">
        </label>

        <input asp-for="Titulo"
               class="form-control"
               placeholder="Ejemplo: Clean Code" />

        <span asp-validation-for="Titulo"
              class="text-danger">
        </span>
    </div>

    <div class="col-md-4 mb-3">
        <label asp-for="Isbn"
               class="form-label">
        </label>

        <input asp-for="Isbn"
               class="form-control"
               placeholder="Ejemplo: 9780132350884" />

        <span asp-validation-for="Isbn"
              class="text-danger">
        </span>
    </div>
</div>

<div class="row">
    <div class="col-md-6 mb-3">
        <label asp-for="Editorial"
               class="form-label">
        </label>

        <input asp-for="Editorial"
               class="form-control"
               placeholder="Ejemplo: Prentice Hall" />

        <span asp-validation-for="Editorial"
              class="text-danger">
        </span>
    </div>

    <div class="col-md-3 mb-3">
        <label asp-for="AnioPublicacion"
               class="form-label">
        </label>

        <input asp-for="AnioPublicacion"
               type="number"
               class="form-control"
               min="1"
               max="9999" />

        <span asp-validation-for="AnioPublicacion"
              class="text-danger">
        </span>
    </div>

    <div class="col-md-3 mb-3">
        <label asp-for="CategoriaId"
               class="form-label">
        </label>

        <select asp-for="CategoriaId"
                asp-items="Model.CategoriasDisponibles"
                class="form-select">

            <option value="">
                Selecciona una categoría
            </option>

        </select>

        <span asp-validation-for="CategoriaId"
              class="text-danger">
        </span>
    </div>
</div>

<div class="mb-3">
    <label asp-for="AutoresSeleccionados"
           class="form-label">
    </label>

    <select asp-for="AutoresSeleccionados"
            asp-items="Model.AutoresDisponibles"
            class="form-select"
            multiple
            size="7">
    </select>

    <span asp-validation-for="AutoresSeleccionados"
          class="text-danger">
    </span>

    <div class="form-text">
        Puedes seleccionar varios autores manteniendo presionada
        la tecla Ctrl mientras haces clic.
    </div>
</div>

<div class="mb-3">
    <label asp-for="Descripcion"
           class="form-label">
    </label>

    <textarea asp-for="Descripcion"
              class="form-control"
              rows="5"
              placeholder="Descripción o resumen del libro"></textarea>

    <span asp-validation-for="Descripcion"
          class="text-danger">
    </span>
</div>

<div class="mb-3">
    <label asp-for="ImagenUrl"
           class="form-label">
    </label>

    <input asp-for="ImagenUrl"
           class="form-control"
           placeholder="Ejemplo: https://sitio.com/portada.jpg" />

    <span asp-validation-for="ImagenUrl"
          class="text-danger">
    </span>

    <div class="form-text">
        La portada es opcional. Después podemos cambiar esto por
        una carga directa de imágenes.
    </div>
</div>

@if (Model.LibroId > 0)
{
    <div class="form-check mb-3">
        <input asp-for="Activo"
               class="form-check-input" />

        <label asp-for="Activo"
               class="form-check-label">
        </label>
    </div>
}

