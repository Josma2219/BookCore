@model BookCore.ViewModels.LibroIndiceViewModel

@{
    ViewData["Title"] = "Libros";
}

<div class="contenedor-pagina">
    <div class="tarjeta-panel">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="mb-1">
                    Libros
                </h1>

                <p class="text-muted mb-0">
                    Administra el catálogo de libros de BookCore.
                </p>
            </div>

            <a asp-action="Crear"
               class="btn btn-primary">
                Nuevo libro
            </a>
        </div>

        <form asp-action="Index"
              method="get"
              class="row g-3 mb-4">

            <div class="col-md-5">
                <label asp-for="Busqueda"
                       class="form-label">
                    Búsqueda
                </label>

                <input asp-for="Busqueda"
                       class="form-control"
                       placeholder="Título, ISBN, editorial o autor" />
            </div>

            <div class="col-md-3">
                <label asp-for="CategoriaId"
                       class="form-label">
                    Categoría
                </label>

                <select asp-for="CategoriaId"
                        asp-items="Model.Categorias"
                        class="form-select">

                    <option value="">
                        Todas las categorías
                    </option>

                </select>
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <div class="form-check mb-2">
                    <input asp-for="SoloActivos"
                           class="form-check-input" />

                    <label asp-for="SoloActivos"
                           class="form-check-label">
                        Solo activos
                    </label>
                </div>
            </div>

            <div class="col-md-2 d-flex align-items-end gap-2">
                <button type="submit"
                        class="btn btn-outline-primary">
                    Buscar
                </button>

                <a asp-action="Index"
                   class="btn btn-outline-secondary">
                    Limpiar
                </a>
            </div>
        </form>

        @if (!Model.Libros.Any())
        {
            <div class="alert alert-info mb-0">
                No se encontraron libros.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Título</th>
                            <th>Autores</th>
                            <th>Categoría</th>
                            <th>ISBN</th>
                            <th>Disponibilidad</th>
                            <th>Estado</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var libro in Model.Libros)
                        {
                            <tr>
                                <td>
                                    <strong>
                                        @libro.Titulo
                                    </strong>

                                    @if (libro.AnioPublicacion.HasValue)
                                    {
                                        <div class="text-muted small">
                                            @libro.AnioPublicacion
                                        </div>
                                    }
                                </td>

                                <td>
                                    @libro.Autores
                                </td>

                                <td>
                                    @libro.CategoriaNombre
                                </td>

                                <td>
                                    @if (string.IsNullOrWhiteSpace(libro.Isbn))
                                    {
                                        <span class="text-muted">
                                            No indicado
                                        </span>
                                    }
                                    else
                                    {
                                        @libro.Isbn
                                    }
                                </td>

                                <td>
                                    @libro.EjemplaresDisponibles
                                    de
                                    @libro.TotalEjemplares
                                </td>

                                <td>
                                    @if (libro.Activo)
                                    {
                                        <span class="badge bg-success">
                                            Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">
                                            Inactivo
                                        </span>
                                    }
                                </td>

                                <td>
                                    <div class="d-flex justify-content-end gap-2">
                                        <a asp-action="Detalle"
                                           asp-route-id="@libro.LibroId"
                                           class="btn btn-sm btn-outline-info">
                                            Detalle
                                        </a>

                                        <a asp-action="Editar"
                                           asp-route-id="@libro.LibroId"
                                           class="btn btn-sm btn-outline-primary">
                                            Editar
                                        </a>

                                        @if (libro.Activo)
                                        {
                                            <a asp-action="Eliminar"
                                               asp-route-id="@libro.LibroId"
                                               class="btn btn-sm btn-outline-danger">
                                                Eliminar
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

    </div>
</div>