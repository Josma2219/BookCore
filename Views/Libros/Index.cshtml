@model BookCore.ViewModels.LibroIndiceViewModel

@{
    ViewData["Title"] = "Libros";
}

<div class="contenedor-pagina">
    <div class="tarjeta-panel">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="mb-1">
                    Libros
                </h1>

                <p class="text-muted mb-0">
                    Administra el catálogo de libros de BookCore.
                </p>
            </div>

            <a asp-action="Crear"
               class="btn btn-primary">
                Nuevo libro
            </a>
        </div>

        <form asp-action="Index"
              method="get"
              class="row g-3 mb-4">

            <div class="col-md-5">
                <label asp-for="Busqueda"
                       class="form-label">
                    Búsqueda
                </label>

                <input asp-for="Busqueda"
                       class="form-control"
                       placeholder="Título, ISBN, editorial o autor" />
            </div>

            <div class="col-md-3">
                <label asp-for="CategoriaId"
                       class="form-label">
                    Categoría
                </label>

                <select asp-for="CategoriaId"
                        asp-items="Model.Categorias"
                        class="form-select">

                    <option value="">
                        Todas las categorías
                    </option>

                </select>
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <div class="form-check mb-2">
                    <input asp-for="SoloActivos"
                           class="form-check-input" />

                    <label asp-for="SoloActivos"
                           class="form-check-label">
                        Solo activos
                    </label>
                </div>
            </div>

            <div class="col-md-2 d-flex align-items-end gap-2">
                <button type="submit"
                        class="btn btn-outline-primary">
                    Buscar
                </button>

                <a asp-action="Index"
                   class="btn btn-outline-secondary">
                    Limpiar
                </a>
            </div>
        </form>

        @if (!Model.Libros.Any())
        {
            <div class="alert alert-info mb-0">
                No se encontraron libros.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Título <i class="bi bi-arrow-down-up orden-columna"></i></th>
                            <th class="col-oculta-angosta">Autores <i class="bi bi-arrow-down-up orden-columna"></i></th>
                            <th>Categoría <i class="bi bi-arrow-down-up orden-columna"></i></th>
                            <th class="col-oculta-angosta">ISBN <i class="bi bi-arrow-down-up orden-columna"></i></th>
                            <th>Disponibilidad <i class="bi bi-arrow-down-up orden-columna"></i></th>
                            <th>Estado <i class="bi bi-arrow-down-up orden-columna"></i></th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var libro in Model.Libros)
                        {
                            <tr>
                                <td>
                                    <div class="libro-celda">
                                        <span class="icono-libro-mini c2">
                                            <i class="bi bi-book"></i>
                                        </span>
                                        <div>
                                            <strong>
                                                @libro.Titulo
                                            </strong>

                                            @if (libro.AnioPublicacion.HasValue)
                                            {
                                                <div class="text-muted small">
                                                    @libro.AnioPublicacion
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </td>

                                <td class="col-oculta-angosta">
                                    @libro.Autores
                                </td>

                                <td>
                                    @libro.CategoriaNombre
                                </td>

                                <td class="col-oculta-angosta">
                                    @if (string.IsNullOrWhiteSpace(libro.Isbn))
                                    {
                                        <span class="text-muted">
                                            No indicado
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="pastilla-codigo">
                                            @libro.Isbn
                                        </span>
                                    }
                                </td>

                                <td>
                                    @libro.EjemplaresDisponibles
                                    de
                                    @libro.TotalEjemplares
                                </td>

                                <td>
                                    @if (libro.Activo)
                                    {
                                        <span class="estado-punto activo">
                                            Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="estado-punto inactivo">
                                            Inactivo
                                        </span>
                                    }
                                </td>

                                <td>
                                    <div class="acciones-tabla">

                                        <a asp-action="Detalle"
                                           asp-route-id="@libro.LibroId"
                                           class="accion-icono ver"
                                           title="Ver detalle">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        <a asp-action="Editar"
                                           asp-route-id="@libro.LibroId"
                                           class="accion-icono editar"
                                           title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>

                                        @if (libro.Activo)
                                        {
                                            <a asp-action="Eliminar"
                                               asp-route-id="@libro.LibroId"
                                               class="accion-icono eliminar"
                                               title="Eliminar">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

    </div>
</div>