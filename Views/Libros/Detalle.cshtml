@model BookCore.ViewModels.LibroDetalleViewModel

@{
    ViewData["Title"] = "Detalle del libro";
}

<div class="contenedor-pagina">
    <div class="tarjeta-panel">

        <div class="row">
            @if (!string.IsNullOrWhiteSpace(Model.ImagenUrl))
            {
                <div class="col-md-3 mb-4">
                    <img src="@Model.ImagenUrl"
                         alt="Portada de @Model.Titulo"
                         class="img-fluid rounded border" />
                </div>
            }

            <div class="@(
                 string.IsNullOrWhiteSpace(Model.ImagenUrl)
                     ? "col-md-12"
                     : "col-md-9")">

                <h1>
                    @Model.Titulo
                </h1>

                <p class="text-muted">
                    @Model.Autores
                </p>

                <dl class="row mt-4">
                    <dt class="col-sm-4">
                        Categoría
                    </dt>

                    <dd class="col-sm-8">
                        @Model.CategoriaNombre
                    </dd>

                    <dt class="col-sm-4">
                        ISBN
                    </dt>

                    <dd class="col-sm-8">
                        @(string.IsNullOrWhiteSpace(Model.Isbn)
                            ? "No indicado"
                            : Model.Isbn)
                    </dd>

                    <dt class="col-sm-4">
                        Editorial
                    </dt>

                    <dd class="col-sm-8">
                        @(string.IsNullOrWhiteSpace(Model.Editorial)
                            ? "No indicada"
                            : Model.Editorial)
                    </dd>

                    <dt class="col-sm-4">
                        Año de publicación
                    </dt>

                    <dd class="col-sm-8">
                        @(Model.AnioPublicacion?.ToString()
                            ?? "No indicado")
                    </dd>

                    <dt class="col-sm-4">
                        Estado
                    </dt>

                    <dd class="col-sm-8">
                        @if (Model.Activo)
                        {
                            <span class="badge bg-success">
                                Activo
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">
                                Inactivo
                            </span>
                        }
                    </dd>

                    <dt class="col-sm-4">
                        Fecha de registro
                    </dt>

                    <dd class="col-sm-8">
                        @(Model.FechaRegistro.ToString(
                            "dd/MM/yyyy HH:mm"))
                    </dd>
                </dl>
            </div>
        </div>

        <hr />

        <h2 class="h4">
            Disponibilidad
        </h2>

        <div class="row mt-3">
            <div class="col-md-3 mb-3">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <strong class="fs-4">
                            @Model.TotalEjemplares
                        </strong>

                        <div>
                            Ejemplares totales
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-3">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <strong class="fs-4">
                            @Model.EjemplaresDisponibles
                        </strong>

                        <div>
                            Disponibles
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-3">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <strong class="fs-4">
                            @Model.EjemplaresPrestados
                        </strong>

                        <div>
                            Prestados
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-3">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <strong class="fs-4">
                            @Model.EjemplaresDanados
                        </strong>

                        <div>
                            Dañados
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <h2 class="h4 mt-3">
            Descripción
        </h2>

        @if (string.IsNullOrWhiteSpace(Model.Descripcion))
        {
            <p class="text-muted">
                Este libro no tiene una descripción registrada.
            </p>
        }
        else
        {
            <p>
                @Model.Descripcion
            </p>
        }

        <div class="d-flex gap-2 mt-4">
            <a asp-action="Editar"
               asp-route-id="@Model.LibroId"
               class="btn btn-primary">
                Editar
            </a>

            <a asp-action="Index"
               class="btn btn-outline-secondary">
                Volver
            </a>
        </div>

    </div>
</div>