@model IEnumerable<BookCore.ViewModels.CategoriaViewModel>

@{
    ViewData["Title"] = "Categorías";
}

<div class="contenedor-pagina">
    <div class="tarjeta-panel">

        <div class="d-flex justify-content-between
            align-items-center mb-4">

            <div>
                <h1 class="mb-1">Categorías</h1>

                <p class="text-muted mb-0">
                    Administra las categorías de los libros.
                </p>
            </div>

            <a asp-action="Crear"
               class="btn btn-primary">
                Nueva categoría
            </a>
        </div>

        @if (!Model.Any())
        {
            <div class="alert alert-info mb-0">
                Todavía no hay categorías registradas.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">

                    <thead>
                        <tr>
                            <th>Nombre <i class="bi bi-arrow-down-up orden-columna"></i></th>
                            <th class="col-oculta-angosta">Descripción <i class="bi bi-arrow-down-up orden-columna"></i></th>
                            <th>Estado <i class="bi bi-arrow-down-up orden-columna"></i></th>
                            <th>Fecha de creación <i class="bi bi-arrow-down-up orden-columna"></i></th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var categoria in Model)
                        {
                            <tr>
                                <td>
                                    <div class="libro-celda">
                                        <span class="icono-libro-mini c4">
                                            <i class="bi bi-folder2-open"></i>
                                        </span>
                                        <strong>@categoria.Nombre</strong>
                                    </div>
                                </td>

                                <td class="col-oculta-angosta">
                                    @if (string.IsNullOrWhiteSpace(
                                        categoria.Descripcion))
                                    {
                                        <span class="text-muted">
                                            Sin descripción
                                        </span>
                                    }
                                    else
                                    {
                                        @categoria.Descripcion
                                    }
                                </td>

                                <td>
                                    @if (categoria.Activo)
                                    {
                                        <span class="estado-punto activo">
                                            Activa
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="estado-punto inactivo">
                                            Inactiva
                                        </span>
                                    }
                                </td>

                                <td>
                                    <span class="fecha-con-icono">
                                        <i class="bi bi-calendar3"></i>
                                        @(categoria.FechaCreacion.ToString("dd/MM/yyyy"))
                                    </span>
                                </td>

                                <td>
                                    <div class="acciones-tabla">

                                        <a asp-action="Detalle"
                                           asp-route-id="@categoria.CategoriaId"
                                           class="accion-icono ver"
                                           title="Ver detalle">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        <a asp-action="Editar"
                                           asp-route-id="@categoria.CategoriaId"
                                           class="accion-icono editar"
                                           title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>

                                        @if (categoria.Activo)
                                        {
                                            <a asp-action="Eliminar"
                                               asp-route-id="@categoria.CategoriaId"
                                               class="accion-icono eliminar"
                                               title="Eliminar">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>
        }
    </div>
</div>