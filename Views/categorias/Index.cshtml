@model IEnumerable<BookCore.ViewModels.CategoriaViewModel>

@{
    ViewData["Title"] = "Categorías";
}

<div class="contenedor-pagina">
    <div class="tarjeta-panel">

        <div class="d-flex justify-content-between
            align-items-center mb-4">

            <div>
                <h1 class="mb-1">Categorías</h1>

                <p class="text-muted mb-0">
                    Administra las categorías de los libros.
                </p>
            </div>

            <a asp-action="Crear"
               class="btn btn-primary">
                Nueva categoría
            </a>
        </div>

        @if (!Model.Any())
        {
            <div class="alert alert-info mb-0">
                Todavía no hay categorías registradas.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">

                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Descripción</th>
                            <th>Estado</th>
                            <th>Fecha de creación</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var categoria in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@categoria.Nombre</strong>
                                </td>

                                <td>
                                    @if (string.IsNullOrWhiteSpace(
                                        categoria.Descripcion))
                                    {
                                        <span class="text-muted">
                                            Sin descripción
                                        </span>
                                    }
                                    else
                                    {
                                        @categoria.Descripcion
                                    }
                                </td>

                                <td>
                                    @if (categoria.Activo)
                                    {
                                        <span class="badge bg-success">
                                            Activa
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">
                                            Inactiva
                                        </span>
                                    }
                                </td>

                                <td>
                                    @(categoria.FechaCreacion.ToString("dd/MM/yyyy"))
                                </td>

                                <td>
                                    <div class="d-flex justify-content-end
                                        gap-2">

                                        <a asp-action="Detalle"
                                           asp-route-id="@categoria.CategoriaId"
                                           class="btn btn-sm btn-outline-info">
                                            Detalle
                                        </a>

                                        <a asp-action="Editar"
                                           asp-route-id="@categoria.CategoriaId"
                                           class="btn btn-sm btn-outline-primary">
                                            Editar
                                        </a>

                                        @if (categoria.Activo)
                                        {
                                            <a asp-action="Eliminar"
                                               asp-route-id="@categoria.CategoriaId"
                                               class="btn btn-sm btn-outline-danger">
                                                Eliminar
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>
        }
    </div>
</div>