@model BookCore.ViewModels.EjemplarFormularioViewModel

<input asp-for="EjemplarId"
       type="hidden" />

<div asp-validation-summary="ModelOnly"
     class="text-danger mb-3">
</div>

<div class="row">
    <div class="col-md-6 mb-3">
        <label asp-for="LibroId"
               class="form-label">
        </label>

        <select asp-for="LibroId"
                asp-items="Model.LibrosDisponibles"
                class="form-select">

            <option value="">
                Selecciona un libro
            </option>

        </select>

        <span asp-validation-for="LibroId"
              class="text-danger">
        </span>
    </div>

    <div class="col-md-6 mb-3">
        <label asp-for="CodigoInterno"
               class="form-label">
        </label>

        <input asp-for="CodigoInterno"
               class="form-control"
               placeholder="Ejemplo: CC-001" />

        <span asp-validation-for="CodigoInterno"
              class="text-danger">
        </span>

        <div class="form-text">
            El código identifica esta copia física en particular.
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6 mb-3">
        <label asp-for="Estado"
               class="form-label">
        </label>

        <select asp-for="Estado"
                asp-items="Model.EstadosDisponibles"
                class="form-select">
        </select>

        <span asp-validation-for="Estado"
              class="text-danger">
        </span>

        <div class="form-text">
            El estado Prestado se asigna automáticamente
            cuando registremos un préstamo.
        </div>
    </div>

    <div class="col-md-6 mb-3">
        <label asp-for="Ubicacion"
               class="form-label">
        </label>

        <input asp-for="Ubicacion"
               class="form-control"
               placeholder="Ejemplo: Estante A, sección 3" />

        <span asp-validation-for="Ubicacion"
              class="text-danger">
        </span>
    </div>
</div>

@if (Model.EjemplarId > 0)
{
    <div class="form-check mb-3">
        <input asp-for="Activo"
               class="form-check-input" />

        <label asp-for="Activo"
               class="form-check-label">
        </label>
    </div>
}

<!-- Aquí ajustamos el diseño cuando trabajemos la interfaz final -->