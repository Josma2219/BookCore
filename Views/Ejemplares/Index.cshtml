@model BookCore.ViewModels.EjemplarIndiceViewModel

@{
    ViewData["Title"] = "Ejemplares";
}

<div class="contenedor-pagina">
    <div class="tarjeta-panel">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="mb-1">
                    Ejemplares
                </h1>

                <p class="text-muted mb-0">
                    Administra las copias físicas de los libros.
                </p>
            </div>

            <a asp-action="Crear"
               asp-route-libroId="@Model.LibroId"
               class="btn btn-primary">
                Nuevo ejemplar
            </a>
        </div>

        <form asp-action="Index"
              method="get"
              class="row g-3 mb-4">

            <div class="col-md-4">
                <label asp-for="Busqueda"
                       class="form-label">
                    Búsqueda
                </label>

                <input asp-for="Busqueda"
                       class="form-control"
                       placeholder="Código, libro o ubicación" />
            </div>

            <div class="col-md-3">
                <label asp-for="LibroId"
                       class="form-label">
                    Libro
                </label>

                <select asp-for="LibroId"
                        asp-items="Model.Libros"
                        class="form-select">

                    <option value="">
                        Todos los libros
                    </option>

                </select>
            </div>

            <div class="col-md-2">
                <label asp-for="Estado"
                       class="form-label">
                    Estado
                </label>

                <select asp-for="Estado"
                        asp-items="Model.Estados"
                        class="form-select">

                    <option value="">
                        Todos
                    </option>

                </select>
            </div>

            <div class="col-md-1 d-flex align-items-end">
                <div class="form-check mb-2">
                    <input asp-for="SoloActivos"
                           class="form-check-input" />

                    <label asp-for="SoloActivos"
                           class="form-check-label">
                        Activos
                    </label>
                </div>
            </div>

            <div class="col-md-2 d-flex align-items-end gap-2">
                <button type="submit"
                        class="btn btn-outline-primary">
                    Buscar
                </button>

                <a asp-action="Index"
                   class="btn btn-outline-secondary">
                    Limpiar
                </a>
            </div>

        </form>

        @if (!Model.Ejemplares.Any())
        {
            <div class="alert alert-info mb-0">
                No se encontraron ejemplares.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Código</th>
                            <th>Libro</th>
                            <th>Ubicación</th>
                            <th>Estado</th>
                            <th>Registro</th>
                            <th>Activo</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var ejemplar in Model.Ejemplares)
                        {
                            <tr>
                                <td>
                                    <strong>
                                        @ejemplar.CodigoInterno
                                    </strong>
                                </td>

                                <td>
                                    @ejemplar.LibroTitulo
                                </td>

                                <td>
                                    @if (string.IsNullOrWhiteSpace(
                                        ejemplar.Ubicacion))
                                    {
                                        <span class="text-muted">
                                            No indicada
                                        </span>
                                    }
                                    else
                                    {
                                        @ejemplar.Ubicacion
                                    }
                                </td>

                                <td>
                                    @switch (ejemplar.Estado)
                                    {
                                        case "Disponible":
                                            <span class="badge bg-success">
                                                Disponible
                                            </span>
                                            break;

                                        case "Prestado":
                                            <span class="badge bg-primary">
                                                Prestado
                                            </span>
                                            break;

                                        case "Dañado":
                                            <span class="badge bg-warning text-dark">
                                                Dañado
                                            </span>
                                            break;

                                        default:
                                            <span class="badge bg-secondary">
                                                Baja
                                            </span>
                                            break;
                                    }
                                </td>

                                <td>
                                    @(ejemplar.FechaIngreso.ToString(
                                        "dd/MM/yyyy"))
                                </td>

                                <td>
                                    @if (ejemplar.Activo)
                                    {
                                        <span class="badge bg-success">
                                            Sí
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">
                                            No
                                        </span>
                                    }
                                </td>

                                <td>
                                    <div class="d-flex justify-content-end gap-2">
                                        <a asp-action="Detalle"
                                           asp-route-id="@ejemplar.EjemplarId"
                                           class="btn btn-sm btn-outline-info">
                                            Detalle
                                        </a>

                                        <a asp-action="Editar"
                                           asp-route-id="@ejemplar.EjemplarId"
                                           class="btn btn-sm btn-outline-primary">
                                            Editar
                                        </a>

                                        @if (ejemplar.Activo)
                                        {
                                            <a asp-action="Eliminar"
                                               asp-route-id="@ejemplar.EjemplarId"
                                               class="btn btn-sm btn-outline-danger">
                                                Eliminar
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

    </div>
</div>