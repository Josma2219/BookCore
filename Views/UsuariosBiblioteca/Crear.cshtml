@model BookCore.ViewModels.UsuarioBibliotecaViewModel

@{
    ViewData["Title"] = "Crear usuario";
}

<div class="contenedor-pagina">
    <div class="tarjeta-panel">

        <div class="mb-4">
            <h1>Crear usuario de biblioteca</h1>

            <p class="text-muted">
                Registra una persona que podrá solicitar libros.
            </p>
        </div>

        <form asp-action="Crear"
              method="post">

            <partial name="_Formulario"
                     model="Model" />

            <div class="d-flex gap-2 mt-4">
                <button type="submit"
                        class="btn btn-primary">
                    Guardar usuario
                </button>

                <a asp-action="Index"
                   class="btn btn-outline-secondary">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}