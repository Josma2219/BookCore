@model BookCore.ViewModels.UsuarioBibliotecaViewModel

<input asp-for="UsuarioBibliotecaId"
       type="hidden" />

<div asp-validation-summary="ModelOnly"
     class="text-danger mb-3">
</div>

<div class="row">
    <div class="col-md-6 mb-3">
        <label asp-for="Nombre"
               class="form-label">
        </label>

        <input asp-for="Nombre"
               class="form-control"
               placeholder="Ejemplo: Ana" />

        <span asp-validation-for="Nombre"
              class="text-danger">
        </span>
    </div>

    <div class="col-md-6 mb-3">
        <label asp-for="Apellidos"
               class="form-label">
        </label>

        <input asp-for="Apellidos"
               class="form-control"
               placeholder="Ejemplo: Rodríguez Mora" />

        <span asp-validation-for="Apellidos"
              class="text-danger">
        </span>
    </div>
</div>

<div class="row">
    <div class="col-md-6 mb-3">
        <label asp-for="Cedula"
               class="form-label">
        </label>

        <input asp-for="Cedula"
               class="form-control"
               placeholder="Ejemplo: 1-1234-5678" />

        <span asp-validation-for="Cedula"
              class="text-danger">
        </span>
    </div>

    <div class="col-md-6 mb-3">
        <label asp-for="Correo"
               class="form-label">
        </label>

        <input asp-for="Correo"
               type="email"
               class="form-control"
               placeholder="Ejemplo: ana@correo.com" />

        <span asp-validation-for="Correo"
              class="text-danger">
        </span>
    </div>
</div>

<div class="row">
    <div class="col-md-6 mb-3">
        <label asp-for="Telefono"
               class="form-label">
        </label>

        <input asp-for="Telefono"
               class="form-control"
               placeholder="Ejemplo: 8888-8888" />

        <span asp-validation-for="Telefono"
              class="text-danger">
        </span>
    </div>

    <div class="col-md-6 mb-3">
        <label asp-for="Direccion"
               class="form-label">
        </label>

        <textarea asp-for="Direccion"
                  class="form-control"
                  rows="3"
                  placeholder="Dirección del usuario"></textarea>

        <span asp-validation-for="Direccion"
              class="text-danger">
        </span>
    </div>
</div>

@if (Model.UsuarioBibliotecaId > 0)
{
    <div class="form-check mb-3">
        <input asp-for="Activo"
               class="form-check-input" />

        <label asp-for="Activo"
               class="form-check-label">
        </label>
    </div>
}

