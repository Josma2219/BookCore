@model IEnumerable<BookCore.ViewModels.UsuarioBibliotecaViewModel>

@{
    ViewData["Title"] = "Usuarios de biblioteca";
}

<div class="contenedor-pagina">
    <div class="tarjeta-panel">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="mb-1">
                    Usuarios de biblioteca
                </h1>

                <p class="text-muted mb-0">
                    Administra las personas que pueden solicitar libros.
                </p>
            </div>

            <a asp-action="Crear"
               class="btn btn-primary">
                Nuevo usuario
            </a>
        </div>

        <form asp-action="Index"
              method="get"
              class="row g-2 mb-4">

            <div class="col-md-9">
                <input type="text"
                       name="busqueda"
                       value="@ViewBag.Busqueda"
                       class="form-control"
                       placeholder="Buscar por nombre, cédula o correo" />
            </div>

            <div class="col-md-3 d-flex gap-2">
                <button type="submit"
                        class="btn btn-outline-primary">
                    Buscar
                </button>

                <a asp-action="Index"
                   class="btn btn-outline-secondary">
                    Limpiar
                </a>
            </div>
        </form>

        @if (!Model.Any())
        {
            <div class="alert alert-info mb-0">
                No se encontraron usuarios de biblioteca.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Nombre completo</th>
                            <th>Identificación</th>
                            <th>Correo</th>
                            <th>Teléfono</th>
                            <th>Estado</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var usuario in Model)
                        {
                            <tr>
                                <td>
                                    <strong>
                                        @usuario.NombreCompleto
                                    </strong>
                                </td>

                                <td>
                                    @usuario.Cedula
                                </td>

                                <td>
                                    @if (string.IsNullOrWhiteSpace(usuario.Correo))
                                    {
                                        <span class="text-muted">
                                            No indicado
                                        </span>
                                    }
                                    else
                                    {
                                        @usuario.Correo
                                    }
                                </td>

                                <td>
                                    @if (string.IsNullOrWhiteSpace(usuario.Telefono))
                                    {
                                        <span class="text-muted">
                                            No indicado
                                        </span>
                                    }
                                    else
                                    {
                                        @usuario.Telefono
                                    }
                                </td>

                                <td>
                                    @if (usuario.Activo)
                                    {
                                        <span class="badge bg-success">
                                            Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">
                                            Inactivo
                                        </span>
                                    }
                                </td>

                                <td>
                                    <div class="d-flex justify-content-end gap-2">
                                        <a asp-action="Detalle"
                                           asp-route-id="@usuario.UsuarioBibliotecaId"
                                           class="btn btn-sm btn-outline-info">
                                            Detalle
                                        </a>

                                        <a asp-action="Editar"
                                           asp-route-id="@usuario.UsuarioBibliotecaId"
                                           class="btn btn-sm btn-outline-primary">
                                            Editar
                                        </a>

                                        @if (usuario.Activo)
                                        {
                                            <a asp-action="Eliminar"
                                               asp-route-id="@usuario.UsuarioBibliotecaId"
                                               class="btn btn-sm btn-outline-danger">
                                                Eliminar
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>