@model IEnumerable<BookCore.ViewModels.UsuarioBibliotecaViewModel>

@{
    ViewData["Title"] = "Usuarios de biblioteca";
}

<div class="contenedor-pagina">
    <div class="tarjeta-panel">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="mb-1">
                    Usuarios de biblioteca
                </h1>

                <p class="text-muted mb-0">
                    Administra las personas que pueden solicitar libros.
                </p>
            </div>

            <a asp-action="Crear"
               class="btn btn-primary">
                Nuevo usuario
            </a>
        </div>

        <form asp-action="Index"
              method="get"
              class="row g-2 mb-4">

            <div class="col-md-9">
                <input type="text"
                       name="busqueda"
                       value="@ViewBag.Busqueda"
                       class="form-control"
                       placeholder="Buscar por nombre, cédula o correo" />
            </div>

            <div class="col-md-3 d-flex gap-2">
                <button type="submit"
                        class="btn btn-outline-primary">
                    Buscar
                </button>

                <a asp-action="Index"
                   class="btn btn-outline-secondary">
                    Limpiar
                </a>
            </div>
        </form>

        @if (!Model.Any())
        {
            <div class="alert alert-info mb-0">
                No se encontraron usuarios de biblioteca.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Nombre completo <i class="bi bi-arrow-down-up orden-columna"></i></th>
                            <th>Identificación <i class="bi bi-arrow-down-up orden-columna"></i></th>
                            <th class="col-oculta-angosta">Correo <i class="bi bi-arrow-down-up orden-columna"></i></th>
                            <th>Teléfono <i class="bi bi-arrow-down-up orden-columna"></i></th>
                            <th>Estado <i class="bi bi-arrow-down-up orden-columna"></i></th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var usuario in Model)
                        {
                            <tr>
                                <td>
                                    <div class="libro-celda">
                                        <span class="icono-libro-mini c1">
                                            <i class="bi bi-person"></i>
                                        </span>
                                        <strong>
                                            @usuario.NombreCompleto
                                        </strong>
                                    </div>
                                </td>

                                <td>
                                    <span class="pastilla-codigo">
                                        @usuario.Cedula
                                    </span>
                                </td>

                                <td class="col-oculta-angosta">
                                    @if (string.IsNullOrWhiteSpace(usuario.Correo))
                                    {
                                        <span class="text-muted">
                                            No indicado
                                        </span>
                                    }
                                    else
                                    {
                                        @usuario.Correo
                                    }
                                </td>

                                <td>
                                    @if (string.IsNullOrWhiteSpace(usuario.Telefono))
                                    {
                                        <span class="text-muted">
                                            No indicado
                                        </span>
                                    }
                                    else
                                    {
                                        @usuario.Telefono
                                    }
                                </td>

                                <td>
                                    @if (usuario.Activo)
                                    {
                                        <span class="estado-punto activo">
                                            Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="estado-punto inactivo">
                                            Inactivo
                                        </span>
                                    }
                                </td>

                                <td>
                                    <div class="acciones-tabla">

                                        <a asp-action="Detalle"
                                           asp-route-id="@usuario.UsuarioBibliotecaId"
                                           class="accion-icono ver"
                                           title="Ver detalle">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        <a asp-action="Editar"
                                           asp-route-id="@usuario.UsuarioBibliotecaId"
                                           class="accion-icono editar"
                                           title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>

                                        @if (usuario.Activo)
                                        {
                                            <a asp-action="Eliminar"
                                               asp-route-id="@usuario.UsuarioBibliotecaId"
                                               class="accion-icono eliminar"
                                               title="Eliminar">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>