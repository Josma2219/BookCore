@model BookCore.ViewModels.UsuarioBibliotecaViewModel

@{
    ViewData["Title"] = "Eliminar usuario";
}

<div class="contenedor-pagina">
    <div class="tarjeta-panel">

        <div class="alert alert-warning">
            El usuario quedará inactivo, pero conservará su historial.
        </div>

        <h1>Eliminar usuario</h1>

        <p>
            ¿Seguro que deseas desactivar a
            <strong>@Model.NombreCompleto</strong>?
        </p>

        <form asp-action="ConfirmarEliminacion"
              method="post">

            <input type="hidden"
                   name="usuarioBibliotecaId"
                   value="@Model.UsuarioBibliotecaId" />

            <div class="d-flex gap-2 mt-4">
                <button type="submit"
                        class="btn btn-danger">
                    Confirmar eliminación
                </button>

                <a asp-action="Index"
                   class="btn btn-outline-secondary">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>