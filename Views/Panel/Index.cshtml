@model BookCore.ViewModels.PanelAdministrativoViewModel

@{
    ViewData["Title"] = "Panel administrativo";

    // Porcentajes calculados a partir de los mismos datos del modelo
    // (no se agrega información nueva en el resumen, solo se visualiza distinto).
    int porcentajeDisponibilidad =
        Model.TotalEjemplaresActivos > 0
            ? (int)Math.Round(
                Model.EjemplaresDisponibles * 100.0 /
                Model.TotalEjemplaresActivos)
            : 0;

    int porcentajeVencidos =
        Model.PrestamosPendientes > 0
            ? (int)Math.Round(
                Model.PrestamosVencidos * 100.0 /
                Model.PrestamosPendientes)
            : 0;

    int porcentajeVencenHoy =
        Model.PrestamosPendientes > 0
            ? (int)Math.Round(
                Model.PrestamosVencenHoy * 100.0 /
                Model.PrestamosPendientes)
            : 0;

    // ============================================================
    // DATOS DE EJEMPLO — SOLO TEMPORAL PARA EL DISEÑO VISUAL.
    //
    // Cuando el backend agregue "LibrosMasRentados" y
    // "LibrosMenosRentados" al PanelAdministrativoViewModel,
    // borrar estas dos listas y usar en su lugar:
    //
    //     Model.LibrosMasRentados
    //     Model.LibrosMenosRentados
    //
    // (deben traer objetos con .Titulo y .TotalPrestamos, igual
    // que estos de ejemplo, para que el resto del código de abajo
    // no necesite cambios).
    // ============================================================
    var librosMasRentadosEjemplo = new List<(string Titulo, int TotalPrestamos)>
    {
        ("Cien años de soledad", 18),
        ("1984", 15),
        ("El principito", 12),
        ("Rayuela", 9),
        ("Ficciones", 7)
    };

    var librosMenosRentadosEjemplo = new List<(string Titulo, int TotalPrestamos)>
    {
        ("Manual de contabilidad avanzada", 0),
        ("Historia de la cerámica", 0),
        ("Introducción al cálculo III", 1),
        ("Geografía regional", 1),
        ("Tratado de botánica", 2)
    };
}

<div class="contenedor-pagina">

    <!-- Encabezado -->
    <div class="panel-encabezado mb-4 flex-wrap">

        <div class="panel-encabezado-icono">
            🗂️
        </div>

        <div class="flex-grow-1">
            <h1 class="h3 mb-1">
                Panel administrativo
            </h1>

            <p class="texto-secundario mb-0">
                Resumen general de la operación de BookCore.
            </p>
        </div>

    </div>

    <div class="row g-4">

        <!-- ============ BLOQUE 1: Ranking de libros ============ -->
        <div class="col-lg-3">

            <div class="tarjeta-panel h-100">

                <h2 class="h5 mb-1">
                    Libros más rentados
                </h2>

                <p class="texto-secundario small mb-3">
                    Según el total de préstamos registrados.
                </p>

                @if (!librosMasRentadosEjemplo.Any())
                {
                    <p class="texto-secundario small mb-0">
                        Todavía no hay préstamos registrados.
                    </p>
                }
                else
                {
                    <div class="mb-4">
                        @{
                            int posicion = 1;
                        }
                        @foreach (var libro in librosMasRentadosEjemplo)
                        {
                            <div class="ranking-item">
                                <span class="ranking-numero top">@posicion</span>
                                <span class="ranking-titulo">@libro.Titulo</span>
                                <span class="ranking-conteo">
                                    @libro.TotalPrestamos
                                    préstamo(s)
                                </span>
                            </div>
                            posicion++;
                        }
                    </div>
                }

                <hr />

                <h2 class="h5 mb-1 mt-3">
                    Libros menos rentados
                </h2>

                <p class="texto-secundario small mb-3">
                    Candidatos a revisar o promocionar.
                </p>

                @if (!librosMenosRentadosEjemplo.Any())
                {
                    <p class="texto-secundario small mb-0">
                        Todavía no hay libros activos registrados.
                    </p>
                }
                else
                {
                    <div>
                        @{
                            int posicionBaja = 1;
                        }
                        @foreach (var libro in librosMenosRentadosEjemplo)
                        {
                            <div class="ranking-item">
                                <span class="ranking-numero bottom">@posicionBaja</span>
                                <span class="ranking-titulo">@libro.Titulo</span>
                                <span class="ranking-conteo">
                                    @libro.TotalPrestamos
                                    préstamo(s)
                                </span>
                            </div>
                            posicionBaja++;
                        }
                    </div>
                }

            </div>

        </div>

        <!-- ============ BLOQUE 2: Resumen central ============ -->
        <div class="col-lg-6">

            <!-- Resumen unificado -->
            <div class="tarjeta-panel panel-resumen mb-4">

                <div class="panel-resumen-item">
                    <div class="panel-resumen-icono">📚</div>
                    <div class="kpi-valor">@Model.TotalLibrosActivos</div>
                    <div class="kpi-etiqueta">Libros activos</div>
                </div>

                <div class="panel-resumen-item acento-info">
                    <div class="panel-resumen-icono">👥</div>
                    <div class="kpi-valor">@Model.TotalUsuariosActivos</div>
                    <div class="kpi-etiqueta">Usuarios activos</div>
                </div>

                <div class="panel-resumen-item acento-verde">
                    <div class="panel-resumen-icono">📦</div>
                    <div class="kpi-valor">@Model.EjemplaresDisponibles</div>
                    <div class="kpi-etiqueta">
                        Ejemplares disponibles
                        <span class="texto-secundario">de @Model.TotalEjemplaresActivos activos</span>
                    </div>
                    <div class="kpi-barra">
                        <span style="width: @(porcentajeDisponibilidad)%;"></span>
                    </div>
                </div>

                <div class="panel-resumen-item acento-ambar">
                    <div class="panel-resumen-icono">⏳</div>
                    <div class="kpi-valor">@Model.PrestamosPendientes</div>
                    <div class="kpi-etiqueta">Préstamos pendientes</div>
                </div>

            </div>

            <!-- Atención requerida -->
            <div class="tarjeta-panel panel-atencion mb-4">

                <div class="panel-atencion-item">

                    <div class="anillo-progreso"
                         style="--valor: @(porcentajeVencidos)%; --color-anillo: #DC3545;">
                        <div class="anillo-progreso-interior">
                            @(porcentajeVencidos)%
                        </div>
                    </div>

                    <div class="flex-grow-1">
                        <h2 class="h6 mb-1">Préstamos vencidos</h2>
                        <p class="texto-secundario small mb-2">Requieren seguimiento.</p>

                        <div class="d-flex align-items-center gap-2">
                            <span class="badge bg-danger">@Model.PrestamosVencidos</span>

                            <a asp-controller="Prestamos"
                               asp-action="Index"
                               asp-route-estado="Vencido"
                               class="btn btn-sm btn-outline-danger">
                                Ver préstamos vencidos
                            </a>
                        </div>
                    </div>

                </div>

                <div class="panel-atencion-item">

                    <div class="anillo-progreso"
                         style="--valor: @(porcentajeVencenHoy)%; --color-anillo: #E8A33D;">
                        <div class="anillo-progreso-interior">
                            @(porcentajeVencenHoy)%
                        </div>
                    </div>

                    <div class="flex-grow-1">
                        <h2 class="h6 mb-1">Vencen hoy</h2>
                        <p class="texto-secundario small mb-2">Préstamos con vencimiento para hoy.</p>

                        <div class="d-flex align-items-center gap-2">
                            <span class="badge" style="background: #E8A33D;">@Model.PrestamosVencenHoy</span>

                            <a asp-controller="Prestamos"
                               asp-action="Index"
                               class="btn btn-sm"
                               style="border: 1px solid #E8A33D; color: #C9862B;">
                                Revisar préstamos
                            </a>
                        </div>
                    </div>

                </div>

            </div>

            <!-- Préstamos recientes -->
            <div class="tarjeta-panel">

                <div class="d-flex flex-wrap justify-content-between
                    align-items-center mb-3 gap-2">

                    <div>
                        <h2 class="h5 mb-1">
                            Préstamos recientes
                        </h2>

                        <p class="texto-secundario mb-0 small">
                            Últimos cinco movimientos registrados.
                        </p>
                    </div>

                    <div class="d-flex align-items-center gap-2">

                        <select id="filtroEstadoPrestamo"
                                class="form-select form-select-sm panel-filtro">
                            <option value="todos">Todos los estados</option>
                            <option value="Activo">Activos</option>
                            <option value="Vencido">Vencidos</option>
                            <option value="Devuelto">Devueltos</option>
                        </select>

                        <a asp-controller="Prestamos"
                           asp-action="Index"
                           class="btn btn-sm btn-outline-primary text-nowrap">
                            Ver historial
                        </a>

                    </div>

                </div>

                @if (!Model.PrestamosRecientes.Any())
                {
                    <div class="alert alert-info mb-0">
                        No hay préstamos registrados.
                    </div>
                }
                else
                {
                    <div class="table-responsive">

                        <table class="table table-hover align-middle"
                               id="tablaPrestamosRecientes">

                            <thead>
                                <tr>
                                    <th>Usuario</th>
                                    <th>Libro</th>
                                    <th>Ejemplar</th>
                                    <th>Fecha</th>
                                    <th>Estado</th>
                                    <th></th>
                                </tr>
                            </thead>

                            <tbody>

                                @foreach (
                                    var prestamo
                                    in Model.PrestamosRecientes)
                                {
                                    <tr data-estado="@prestamo.Estado">

                                        <td>
                                            @prestamo.UsuarioNombreCompleto

                                            <div class="small text-muted">
                                                @prestamo.UsuarioCedula
                                            </div>
                                        </td>

                                        <td>
                                            @prestamo.LibroTitulo
                                        </td>

                                        <td>
                                            @prestamo.EjemplarCodigo
                                        </td>

                                        <td>
                                            @(prestamo.FechaPrestamo
                                                .ToString(
                                                    "dd/MM/yyyy"))
                                        </td>

                                        <td>
                                            @switch (prestamo.Estado)
                                            {
                                                case "Activo":
                                                    <span class="badge bg-primary">
                                                        Activo
                                                    </span>
                                                    break;

                                                case "Vencido":
                                                    <span class="badge bg-danger">
                                                        Vencido
                                                    </span>
                                                    break;

                                                default:
                                                    <span class="badge bg-success">
                                                        Devuelto
                                                    </span>
                                                    break;
                                            }
                                        </td>

                                        <td class="text-end">
                                            <a asp-controller="Prestamos"
                                               asp-action="Detalle"
                                               asp-route-id="@prestamo.PrestamoId"
                                               class="btn btn-sm
                                                btn-outline-info">
                                                Ver
                                            </a>
                                        </td>

                                    </tr>
                                }

                                <tr id="filaSinResultados"
                                    class="d-none">
                                    <td colspan="6"
                                        class="text-center texto-secundario py-4">
                                        No hay préstamos con ese estado.
                                    </td>
                                </tr>

                            </tbody>

                        </table>

                    </div>
                }

            </div>

        </div>

        <!-- ============ BLOQUE 3: Acciones ============ -->
        <div class="col-lg-3">

            <div class="tarjeta-panel h-100">

                <h2 class="h5 mb-3">
                    Acciones rápidas
                </h2>

                <a asp-controller="Prestamos"
                   asp-action="Crear"
                   class="btn btn-primary w-100 mb-3">
                    ➕ Registrar préstamo
                </a>

                <div class="d-flex flex-column gap-2">

                    <a asp-controller="UsuariosBiblioteca"
                       asp-action="Crear"
                       class="accion-columna">
                        <span class="accion-columna-icono">🧑‍🤝‍🧑</span>
                        Registrar usuario
                    </a>

                    <a asp-controller="Libros"
                       asp-action="Crear"
                       class="accion-columna">
                        <span class="accion-columna-icono">📘</span>
                        Registrar libro
                    </a>

                    <a asp-controller="Ejemplares"
                       asp-action="Crear"
                       class="accion-columna">
                        <span class="accion-columna-icono">🏷️</span>
                        Registrar ejemplar
                    </a>

                    <a asp-controller="Categorias"
                       asp-action="Crear"
                       class="accion-columna">
                        <span class="accion-columna-icono">🗂️</span>
                        Registrar categoría
                    </a>

                    <a asp-controller="Autores"
                       asp-action="Crear"
                       class="accion-columna">
                        <span class="accion-columna-icono">✍️</span>
                        Registrar autor
                    </a>

                    <hr class="my-1" />

                    <a asp-controller="Catalogo"
                       asp-action="Index"
                       class="accion-columna">
                        <span class="accion-columna-icono">🌐</span>
                        Abrir catálogo público
                    </a>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <script>
        (function() {
            var filtro = document.getElementById("filtroEstadoPrestamo");

            if (!filtro) {
                return;
            }

            filtro.addEventListener("change", function() {
                var valor = filtro.value;
                var filas = document.querySelectorAll(
                    "#tablaPrestamosRecientes tbody tr[data-estado]");
                var visibles = 0;

                filas.forEach(function(fila) {
                    var coincide =
                        valor === "todos" ||
                        fila.getAttribute("data-estado") === valor;

                    fila.classList.toggle("d-none", !coincide);

                    if (coincide) {
                        visibles++;
                    }
                });

                var filaVacia = document.getElementById("filaSinResultados");

                if (filaVacia) {
                    filaVacia.classList.toggle("d-none", visibles !== 0);
                }
            });
        })();
    </script>
}