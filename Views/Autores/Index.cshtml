@model IEnumerable<BookCore.ViewModels.AutorViewModel>

@{
    ViewData["Title"] = "Autores";
}

<div class="contenedor-pagina">
    <div class="tarjeta-panel">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="mb-1">Autores</h1>

                <p class="text-muted mb-0">
                    Administra los autores registrados en la biblioteca.
                </p>
            </div>

            <a asp-action="Crear"
               class="btn btn-primary">
                Nuevo autor
            </a>
        </div>

        @if (!Model.Any())
        {
            <div class="alert alert-info mb-0">
                Todavía no hay autores registrados.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Nombre completo <i class="bi bi-arrow-down-up orden-columna"></i></th>
                            <th class="col-oculta-angosta">Nacionalidad <i class="bi bi-arrow-down-up orden-columna"></i></th>
                            <th>Fecha de nacimiento <i class="bi bi-arrow-down-up orden-columna"></i></th>
                            <th>Estado <i class="bi bi-arrow-down-up orden-columna"></i></th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var autor in Model)
                        {
                            <tr>
                                <td>
                                    <div class="libro-celda">
                                        <span class="icono-libro-mini c3">
                                            <i class="bi bi-person-vcard"></i>
                                        </span>
                                        <strong>
                                            @autor.NombreCompleto
                                        </strong>
                                    </div>
                                </td>

                                <td class="col-oculta-angosta">
                                    @if (string.IsNullOrWhiteSpace(
                                        autor.Nacionalidad))
                                    {
                                        <span class="text-muted">
                                            No indicada
                                        </span>
                                    }
                                    else
                                    {
                                        @autor.Nacionalidad
                                    }
                                </td>
                                <td>
                                    @if (autor.FechaNacimiento.HasValue)
                                    {
                                        <span class="fecha-con-icono">
                                            <i class="bi bi-calendar3"></i>
                                            @(autor.FechaNacimiento.Value.ToString("dd/MM/yyyy"))
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">
                                            No indicada
                                        </span>
                                    }
                                </td>

                                <td>
                                    @if (autor.Activo)
                                    {
                                        <span class="estado-punto activo">
                                            Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="estado-punto inactivo">
                                            Inactivo
                                        </span>
                                    }
                                </td>

                                <td>
                                    <div class="acciones-tabla">

                                        <a asp-action="Detalle"
                                           asp-route-id="@autor.AutorId"
                                           class="accion-icono ver"
                                           title="Ver detalle">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        <a asp-action="Editar"
                                           asp-route-id="@autor.AutorId"
                                           class="accion-icono editar"
                                           title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>

                                        @if (autor.Activo)
                                        {
                                            <a asp-action="Eliminar"
                                               asp-route-id="@autor.AutorId"
                                               class="accion-icono eliminar"
                                               title="Eliminar">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>