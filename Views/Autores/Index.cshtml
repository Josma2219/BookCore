@model IEnumerable<BookCore.ViewModels.AutorViewModel>

@{
    ViewData["Title"] = "Autores";
}

<div class="contenedor-pagina">
    <div class="tarjeta-panel">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="mb-1">Autores</h1>

                <p class="text-muted mb-0">
                    Administra los autores registrados en la biblioteca.
                </p>
            </div>

            <a asp-action="Crear"
               class="btn btn-primary">
                Nuevo autor
            </a>
        </div>

        @if (!Model.Any())
        {
            <div class="alert alert-info mb-0">
                Todavía no hay autores registrados.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Nombre completo</th>
                            <th>Nacionalidad</th>
                            <th>Fecha de nacimiento</th>
                            <th>Estado</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var autor in Model)
                        {
                            <tr>
                                <td>
                                    <strong>
                                        @autor.NombreCompleto
                                    </strong>
                                </td>

                                <td>
                                    @if (string.IsNullOrWhiteSpace(
                                        autor.Nacionalidad))
                                    {
                                        <span class="text-muted">
                                            No indicada
                                        </span>
                                    }
                                    else
                                    {
                                        @autor.Nacionalidad
                                    }
                                </td>
                                <td>
                                    @if (autor.FechaNacimiento.HasValue)
                                    {
                                        @(autor.FechaNacimiento.Value.ToString("dd/MM/yyyy"))
                                    }
                                    else
                                    {
                                        <span class="text-muted">
                                            No indicada
                                        </span>
                                    }
                                </td>

                                <td>
                                    @if (autor.Activo)
                                    {
                                        <span class="badge bg-success">
                                            Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">
                                            Inactivo
                                        </span>
                                    }
                                </td>

                                <td>
                                    <div class="d-flex justify-content-end gap-2">
                                        <a asp-action="Detalle"
                                           asp-route-id="@autor.AutorId"
                                           class="btn btn-sm btn-outline-info">
                                            Detalle
                                        </a>

                                        <a asp-action="Editar"
                                           asp-route-id="@autor.AutorId"
                                           class="btn btn-sm btn-outline-primary">
                                            Editar
                                        </a>

                                        @if (autor.Activo)
                                        {
                                            <a asp-action="Eliminar"
                                               asp-route-id="@autor.AutorId"
                                               class="btn btn-sm btn-outline-danger">
                                                Eliminar
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>