@model BookCore.ViewModels.AutorViewModel

@{
    ViewData["Title"] = "Detalle del autor";
}

<div class="contenedor-pagina">
    <div class="tarjeta-panel">

        <div class="mb-4">
            <h1>Detalle del autor</h1>

            <p class="text-muted">
                Información registrada para este autor.
            </p>
        </div>

        <dl class="row">
            <dt class="col-sm-3">
                Nombre completo
            </dt>

            <dd class="col-sm-9">
                @Model.NombreCompleto
            </dd>

            <dt class="col-sm-3">
                Nacionalidad
            </dt>

            <dd class="col-sm-9">
                @if (string.IsNullOrWhiteSpace(Model.Nacionalidad))
                {
                    <span class="text-muted">
                        No indicada
                    </span>
                }
                else
                {
                    @Model.Nacionalidad
                }
            </dd>

            <dt class="col-sm-3">
                Fecha de nacimiento
            </dt>

            <dd class="col-sm-9">
                @if (Model.FechaNacimiento.HasValue)
                {
                    @(Model.FechaNacimiento.Value.ToString("dd/MM/yyyy"))
                }
                else
                {
                    <span class="text-muted">
                        No indicada
                    </span>
                }
            </dd>

            <dt class="col-sm-3">
                Biografía
            </dt>

            <dd class="col-sm-9">
                @if (string.IsNullOrWhiteSpace(Model.Biografia))
                {
                    <span class="text-muted">
                        Sin biografía
                    </span>
                }
                else
                {
                    @Model.Biografia
                }
            </dd>

            <dt class="col-sm-3">
                Estado
            </dt>

            <dd class="col-sm-9">
                @if (Model.Activo)
                {
                    <span class="badge bg-success">
                        Activo
                    </span>
                }
                else
                {
                    <span class="badge bg-secondary">
                        Inactivo
                    </span>
                }
            </dd>

            <dt class="col-sm-3">
                Fecha de registro
            </dt>

            <dd class="col-sm-9">
                @Model.FechaCreacion.ToString(
                    "dd/MM/yyyy HH:mm")
            </dd>
        </dl>

        <div class="d-flex gap-2 mt-4">
            <a asp-action="Editar"
               asp-route-id="@Model.AutorId"
               class="btn btn-primary">
                Editar
            </a>

            <a asp-action="Index"
               class="btn btn-outline-secondary">
                Volver
            </a>
        </div>
    </div>
</div>